{
  "name": "@disclaude/primary-node",
  "version": "0.0.1",
  "description": "Primary Node process for disclaude - handles channels, platforms, and coordination",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "disclaude-primary": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@disclaude/core": "*",
    "@disclaude/worker-node": "*",
    "@larksuiteoapi/node-sdk": "^1.34.0",
    "@types/qrcode": "1.5.6",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "qrcode": "1.5.4",
    "uuid": "^11.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pino": "^7.0.4",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  }
}
