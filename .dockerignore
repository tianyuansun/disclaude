# Dependencies
node_modules/
npm-lock.yaml
npm-debug.log*
yarn.lock
pnpm-lock.yaml

# Git
.git/
.gitignore
.gitattributes

# CI/CD
.github/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test coverage
coverage/
.nyc_output/

# Tests (not needed in production)
tests/
*.test.ts
*.spec.ts
vitest.config.ts
__tests__/

# Documentation
*.md
!CLAUDE.md
!skills/*/SKILL.md

# Configuration (should be mounted as volume)
disclaude.config.yaml
.disclauderc
.env
.env.*

# Logs
logs/
*.log

# PM2
.pm2/

# Claude Code
.claude/

# Playwright MCP
.playwright-mcp/
.mcp.json

# Task records
tasks/

# Workspace (mounted as volume)
workspace/*

# Build output (will be generated in container)
dist/

# Docker files (not needed in image)
Dockerfile*
docker-compose*
.dockerignore

# PM2 example configs (not needed in production)
ecosystem.config.example.cjs
ecosystem.config.conda.example.cjs
ecosystem.config.shell.example.cjs

# Analysis reports (not needed in production)
*_ANALYSIS.md
*_REPORT.md

# Misc
*.orig
repl.history
*.bak
*.tmp
