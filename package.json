{
  "name": "disclaude",
  "version": "0.3.1",
  "description": "Multi-platform agent bot supporting Feishu/Lark and CLI",
  "main": "dist/cli-entry.js",
  "type": "module",
  "bin": {
    "disclaude": "./dist/cli-entry.js"
  },
  "files": [
    "dist",
    "skills",
    "package.json"
  ],
  "scripts": {
    "dev": "tsx watch src/cli-entry.ts",
    "start": "node dist/cli-entry.js --help",
    "cli": "tsx src/cli-entry.ts",
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:integration": "./tests/integration/run-all-tests.sh",
    "test:integration:rest": "./tests/integration/rest-channel-test.sh",
    "test:integration:use-case-1": "./tests/integration/use-case-1-basic-reply.sh",
    "test:integration:use-case-2": "./tests/integration/use-case-2-task-execution.sh",
    "pm2:start": "npm run build && pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop disclaude-feishu",
    "pm2:restart": "pm2 restart disclaude-feishu",
    "pm2:reload": "pm2 reload disclaude-feishu",
    "pm2:logs": "pm2 logs disclaude-feishu --nostream",
    "pm2:logs:follow": "pm2 logs disclaude-feishu",
    "pm2:logs:err": "pm2 logs disclaude-feishu --nostream --err",
    "pm2:logs:out": "pm2 logs disclaude-feishu --nostream --out",
    "pm2:status": "pm2 status",
    "pm2:delete": "pm2 delete disclaude-feishu",
    "pm2:monit": "pm2 monit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.62",
    "@anthropic-ai/sdk": "^0.78.0",
    "@larksuiteoapi/node-sdk": "^1.34.0",
    "@playwright/mcp": "^0.0.61",
    "commander": "^12.1.0",
    "cron": "4.4.0",
    "dotenv": "^16.4.7",
    "js-yaml": "^4.1.1",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "uuid": "13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cron": "2.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.5",
    "@types/pino": "^7.0.4",
    "@types/pino-pretty": "^4.7.5",
    "@types/uuid": "10.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.17.0",
    "pm2": "^6.0.14",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.19.1",
    "vitest": "^3.0.0",
    "vitest-tsconfig-paths": "^3.4.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
