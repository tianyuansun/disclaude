{
  "apps": [{
    "name": "disclaude-worker",
    "script": "packages/worker-node/dist/cli.js",
    "args": "start --mode worker",
    "instances": 1,
    "autorestart": true,
    "watch": false,
    "max_memory_restart": "4G",
    "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
    "error_file": "/app/logs/pm2-error.log",
    "out_file": "/app/logs/pm2-out.log",
    "merge_logs": true,
    "env": {
      "NODE_ENV": "production"
    }
  }]
}
